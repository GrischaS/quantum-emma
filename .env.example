# ============================================================
#  QUANTUM EMMA — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git!
#  © 2026 Grigori Saks — All Rights Reserved
# ============================================================

# ─── DEPLOYER WALLET ─────────────────────────────────────────
# Your wallet private key (WITHOUT 0x prefix is also fine)
# ⚠️  USE A DEDICATED DEPLOY WALLET — never your main wallet!
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# ─── RPC PROVIDERS ───────────────────────────────────────────
# Alchemy (recommended): https://alchemy.com → Create App → Ethereum Sepolia
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Infura (alternative): https://infura.io → Create Project
INFURA_API_KEY=your_infura_api_key_here

# ─── ETHERSCAN VERIFICATION ───────────────────────────────────
# https://etherscan.io → Sign in → API Keys → Add
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ─── OPTIONAL ─────────────────────────────────────────────────
COINMARKETCAP_API_KEY=your_cmc_key_for_gas_reporter
POLYGONSCAN_API_KEY=your_polygonscan_key_for_polygon_deploy
REPORT_GAS=false
